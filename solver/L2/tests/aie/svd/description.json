{
    "name": "Xilinx DSPLIB svd",
    "description": "",
    "gui": false,
    "flow": "aie",
    "platform_allowlist": [
        "vck190",
        "vek280"
    ],
    "part_allowlist": [
        "xcvr1602-vsva2488-2LP-e-S-es1",
        "xc2ve3858-ssva2112-2LP-e-S"
    ],
    "part_alias": {
        "xc2ve3858-ssva2112-2LP-e-S": "aie_mlv2"
    },
    "platform_properties": {
        "vck190": {
            "param_set": [
                "*_aie1_*"
            ],
            "v++": {
                "compiler": {
                    "clflags": []
                },
                "linker": {
                    "ldclflags": [
                        "--config PROJECT/system.cfg"
                    ]
                }
            }
        },
        "vek280": {
            "param_set": [
                "*_aie2_*"
            ],
            "v++": {
                "compiler": {
                    "clflags": []
                },
                "linker": {
                    "ldclflags": [
                        "--config PROJECT/system.cfg"
                    ]
                }
            },
            "aiecompiler": {
                "compiler": {
                    "customized_params": {
                        "default": {
                            "FIFO_THRESHOLD": " "
                        }
                    }
                }
            }
        }
    },
    "part_properties": {
        "xcvr1602-vsva2488-2LP-e-S-es1": {
            "param_set": [
                "*canary_aie"
            ],
            "v++": {
                "compiler": {
                    "clflags": []
                },
                "linker": {
                    "ldclflags": [
                        "--config PROJECT/system.cfg"
                    ]
                }
            },
            "aiecompiler": {
                "compiler": {
                    "customized_params": {
                        "default": {
                            "COMPILER_ARGS": "",
                            "AIE_VARIANT": "1",
                            "FIFO_THRESHOLD": " "
                        }
                    }
                }
            }
        },
        "xc2ve3858-ssva2112-2LP-e-S": {
            "param_set": [
                "*_aie22_*"
            ],
            "v++": {
                "compiler": {
                    "clflags": []
                },
                "linker": {
                    "ldclflags": [
                        "--config PROJECT/system.cfg"
                    ]
                }
            },
            "aiecompiler": {
                "compiler": {
                    "customized_params": {
                        "default": {
                            "COMPILER_ARGS": "",
                            "AIE_VARIANT": "22",
                            "FIFO_THRESHOLD": "--aie.swfifo-threshold=120 "
                        }
                    }
                }
            }
        }
    },
    "pre_build": [
        {
            "build_cmd": " mkdir -p logs"
        },
        {
            "build_cmd": "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f helper.mk get_status HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR UUT_KERNEL=$(UUT_KERNEL)\")"
        },
        {
            "build_cmd": "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f helper.mk create_config HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR UUT_KERNEL=$(UUT_KERNEL)\")"
        },
        {
            "build_cmd": "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/$(DSP_DIR)/L2/meta/scripts/metadata_checker.py --ip $(UUT_KERNEL) --lib_dir LIB_DIR)"
        },
        {
            "build_cmd": "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR LOC_INPUT_FILE=$(LOC_INPUT_FILE)  UUT_KERNEL=$(UUT_KERNEL)\")"
        }
    ],
    "post_launch": [
        {
            "target": "aiesim",
            "launch_cmd": [
                "$(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk prep_aie_out HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR UUT_KERNEL=$(UUT_KERNEL) UUT_SIM_FILE=$(UUT_SIM_FILE_S) \"",
                "$(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk get_diff HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR LOC_INPUT_FILE=$(LOC_INPUT_FILE) UUT_KERNEL=$(UUT_KERNEL) UUT_SIM_FILE=$(UUT_SIM_FILE_S) VITIS_PYTHON3='$(VITIS_PYTHON3)'\"",
                "$(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk get_status HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR UUT_KERNEL=$(UUT_KERNEL) UUT_SIM_FILE=$(UUT_SIM_FILE_S) \"",
                "$(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk get_qor HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR UUT_KERNEL=$(UUT_KERNEL) UUT_SIM_FILE=$(UUT_SIM_FILE_S) \"",
                "tclsh LIB_DIR/$(DSP_DIR)/L2/tests/aie/common/scripts/diff_exit.tcl ./",
                "$(if $(filter-out REF,$(TAG)), $(if $(filter 1,$(CLEANUP_AFTER_TEST)), make ultraclean))"
            ]
        },
        {
            "target": "x86sim",
            "launch_cmd": [
                "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk prep_x86_out HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR UUT_KERNEL=$(UUT_KERNEL)\")",
                "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk get_diff HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR LOC_INPUT_FILE=$(LOC_INPUT_FILE) UUT_SIM_FILE=$(UUT_SIM_FILE_S) UUT_KERNEL=$(UUT_KERNEL) VITIS_PYTHON3='$(VITIS_PYTHON3)'\")",
                "$(if $(filter-out REF,$(TAG)), $(VITIS_PYTHON3) LIB_DIR/L2/tests/aie/common/scripts/paramenv.py --parameter_file $(PARAMS_FILE) --instance_name $(PARAMS) --command \"make -f PROJECT/helper.mk get_status HELPER_CUR_DIR=PROJECT DSP_ROOT_DIR=LIB_DIR/$(DSP_DIR)  HELPER_ROOT_DIR=LIB_DIR LOC_INPUT_FILE=$(LOC_INPUT_FILE) UUT_SIM_FILE=$(UUT_SIM_FILE_S) UUT_KERNEL=$(UUT_KERNEL)\")",
                "$(if $(filter-out REF,$(TAG)), tclsh LIB_DIR/$(DSP_DIR)/L2/tests/aie/common/scripts/diff_exit.tcl ./)",
                "$(if $(filter-out REF,$(TAG)), $(if $(filter 1,$(CLEANUP_AFTER_TEST)), make ultraclean))"
            ]
        }
    ],
    "launch": [
        {
            "name": "aiesim-launch",
            "target": "aiesim",
            "sim_options": "--graph-latency"
        },
        {
            "name": "x86sim-launch",
            "target": "x86sim"
        }
    ],
    "aiecompiler": {
        "compiler": {
            "includepaths": [
                "LIB_DIR/L1/include/aie",
                "LIB_DIR/L1/src/aie",
                "LIB_DIR/L1/tests/aie/inc",
                "LIB_DIR/L1/tests/aie/src",
                "LIB_DIR/L2/include/aie",
                "LIB_DIR/L2/tests/aie/common/inc",
                "LIB_DIR/$(DSP_DIR)/L1/include/aie",
                "LIB_DIR/$(DSP_DIR)/L1/tests/aie/inc",
                "LIB_DIR/$(DSP_DIR)/L2/include/aie",
                "LIB_DIR/$(DSP_DIR)/L2/tests/aie/common/inc",
                "./"
            ],
            "customized_params": {
                "params": "--aie.verbose  $($(TAG)_TARGET_COMPILE_ARGS)  $($(TAG)_PREPROC_ARGS)",
                "default": {
                    "TAG": "UUT",
                    "DSP_DIR": "../dsp",
                    "UUT_KERNEL": "svd",
                    "UUT_GRAPH": "svd_graph",
                    "STACKSIZE_VAL": "900",
                    "UUT_SIM_FILE_U": "./data/uut_output_U.txt",
                    "UUT_SIM_FILE_S": "./data/uut_output_S.txt",
                    "UUT_SIM_FILE_V": "./data/uut_output_V.txt",
                    "LOC_INPUT_FILE": "./data/input.txt",
                    "UUT_TARGET_COMPILE_ARGS": " $(FIFO_THRESHOLD) --aie.Xchess=llvm.xargs=\"-std=c++2a\" --aie.Xchess=main:backend.mist2.xargs=\"+NOdra\" --aie.Xchess=main:backend.mist2.pnll=\"off\"",
                    "PREPROC_ARGS": "",
                    "UUT_PREPROC_ARGS": "--aie.Xpreproc=-DUUT_GRAPH=$(UUT_GRAPH) --aie.Xpreproc=-DINPUT_FILE=$(LOC_INPUT_FILE) --aie.Xpreproc=-DOUTPUT_FILE_U=$(UUT_SIM_FILE_U) --aie.Xpreproc=-DOUTPUT_FILE_S=$(UUT_SIM_FILE_S) --aie.Xpreproc=-DOUTPUT_FILE_V=$(UUT_SIM_FILE_V) $(PREPROC_ARGS) --aie.Xpreproc=-DUSING_UUT=1"
                }
            }
        }
    },
    "aiecontainers": [
        {
            "accelerators": [
                {
                    "location": "test.cpp",
                    "files": [
                        "LIB_DIR/L1/src/aie/svd.cpp",
                        "uut_config.h"
                    ],
                    "pl-freq": 625,
                    "workdir": "./Work",
                    "options": "",
                    "name": "libadf.a"
                }
            ]
        }
    ],
    "generators": {
        "uut_config.h": {
            "file": "LIB_DIR/$(DSP_DIR)/L2/tests/aie/common/scripts/tb_gen.py",
            "function": "generate_testbench"
        }
    },
    "config_make": "LIB_DIR/L2/tests/aie/common/scripts/params.mk",
    "associated_files": [
        "LIB_DIR/L2/tests/aie/common/scripts",
        "LIB_DIR/L2/meta/*common*",
        "LIB_DIR/L2/meta/svd*"
    ],
    "parameter_file": "multi_params.json",
    "testinfo": {
        "disable": false,
        "jobs": [
            {
                "index": 0,
                "dependency": [],
                "env": "",
                "cmd": "",
                "max_memory_MB": {
                    "vitis_aie_x86sim": 8192,
                    "vitis_aie_sim": 8192
                },
                "max_time_min": {
                    "vitis_aie_x86sim": 470,
                    "vitis_aie_sim": 470
                }
            }
        ],
        "customized_params": "multi_params.json",
        "targets": [
            "vitis_aie_sim",
            "vitis_aie_x86sim"
        ],
        "category": "canary",
        "param_set": {
            "pull_req": {
                "*_canary_aie": [
                    "vitis_aie_sim",
                    "vitis_aie_x86sim"
                ],
                "*_hw_checkin": [
                    "vitis_aie_sim",
                    "vitis_aie_x86sim"
                ],
                "*_x86sim_checkin": [
                    "vitis_aie_x86sim"
                ]
            },
            "daily": {
                "*_canary_aie": [
                    "vitis_aie_sim",
                    "vitis_aie_x86sim"
                ],
                "*_hw_qor": [
                    "vitis_aie_sim",
                    "vitis_aie_x86sim"
                ],
                "*_x86sim_qor": [
                    "vitis_aie_x86sim"
                ]
            }
        }
    }
}
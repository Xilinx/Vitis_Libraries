{
    "name": "L2 graph scanline Test",
    "description": "graph scanline Test",
    "flow": "aie",
    "platform_allowlist": [
        "vck190"
    ],
    "platform_properties": {
        "vck190": {
            "v++": {
                "package": {
                    "clflags": [
                        "--package.defer_aie_run"
                    ]
                }
            }
        }
    },
    "gui": true,
    "data": [
        "PROJECT/data",
        "PROJECT/data_model"
    ],
    "aiecompiler": {
        "compiler": {
            "includepaths": [
                "LIB_DIR/L1/include/",
                "LIB_DIR/L2/include/",
                "$(XILINX_HLS)/include",
                "LIB_DIR/L3/models/include/",
                "./"
            ]
        }
    },
    "aiecontainers": [
        {
            "accelerators": [
                {
                    "location": "LIB_DIR/L2/tests/graph_scanline/aie_graph/graph.cpp",
                    "workdir": "./Work",
                    "name": "libadf.a",
                    "config": "aie.cfg",
                    "files": [
                        "LIB_DIR/L1/include/kernel_imagepoints/kernel_imagepoints.cpp",
                        "LIB_DIR/L1/include/kernel_focusing/kernel_focusing.cpp",
                        "LIB_DIR/L1/include/kernel_delay/kernel_delay.cpp",
                        "LIB_DIR/L1/include/kernel_sample/kernel_sample.cpp",
                        "LIB_DIR/L1/include/kernel_interpolation/kernel_interpolation.cpp",
                        "LIB_DIR/L1/include/kernel_apodization/kernel_apodization_pre.cpp",
                        "LIB_DIR/L1/include/kernel_apodization/kernel_apodization_main.cpp",
                        "LIB_DIR/L1/include/kernel_mult/kernel_mult.cpp"
                    ]
                }
            ]
        }
    ],
    "testinfo": {
        "disable": false,
        "jobs": [
            {
                "index": 0,
                "dependency": [],
                "max_memory_MB": {
                    "vitis_aie_sim": 32768,
                    "vitis_aie_x86sim": 32768
                },
                "max_time_min": 470
            }
        ],
        "targets": [
            "vitis_aie_sim",
            "vitis_aie_x86sim"
        ],
        "category": "canary"
    },
    "aie_types": [
        "AIE1"
    ]
}
